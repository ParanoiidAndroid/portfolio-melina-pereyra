# Configuración del servidor
PORT=3001
NODE_ENV=development

# ===== OPCIÓN 1: SENDGRID (RECOMENDADO PARA RENDER) =====
# Obtén tu API Key en: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=tu-sendgrid-api-key-aqui
SENDGRID_FROM_EMAIL=noreply@tudominio.com
EMAIL_TO=melina.lujan.pereyra@gmail.com

# ===== OPCIÓN 2: NODEMAILER + GMAIL (SOLO PARA DESARROLLO LOCAL) =====
# NOTA: Gmail SMTP NO funciona en Render Free Tier por puertos bloqueados
# Solo descomentar estas líneas si estás en desarrollo local
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=tu-email@gmail.com
# EMAIL_PASS=tu-password-de-aplicacion
# EMAIL_FROM=contacto@portfolio.com
# EMAIL_TO=melina.lujan.pereyra@gmail.com

# Configuración de CORS
# Para desarrollo local
FRONTEND_URL=http://localhost:5173
# Para producción (Vercel)
# FRONTEND_URL=https://portfolio-melina-pereyra.vercel.app
